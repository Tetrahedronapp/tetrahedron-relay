    "cf:deploy": "wrangler deploy",
    "cf:tail": "wrangler tail"
  },
  "devDependencies": {
    "vercel": "^37.0.0",
    "wrangler": "^3.78.0",
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
